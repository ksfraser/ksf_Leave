{
    "name": "ksfraser/ksf_leave",
    "description": "KSF Leave Management Library",
    "type": "library",
    "license": "GPL-3.0",
    "require": {
        "php": "^8.1",
        "ksfraser/database": "*",
        "ksfraser/ksf-modules-dao": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\Leave\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\Leave\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {"type": "path", "url": "../Database"},
        {"type": "path", "url": "../ksf_ModulesDAO"}
    ]
}